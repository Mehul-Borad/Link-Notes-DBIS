+  const [ac, setAc] = useState({ active: false, matches: [], selected: 0 });
+  const [uploading, setUploading] = useState(false);
+
+  const insertAtCursor = (snippet) => {
+    const ta = taRef.current;
+    const caret = ta?.selectionStart ?? value.length;
+    const next = value.slice(0, caret) + snippet + value.slice(caret);
+    onChange(next);
+    setTimeout(() => {
+      ta?.focus();
+      const pos = caret + snippet.length;
+      ta?.setSelectionRange(pos, pos);
+    }, 0);
+  };
+
+  const handleUpload = async (e) => {
+    const file = e.target.files?.[0];
+    e.target.value = "";
+    if (!file) return;
+    setUploading(true);
+    try {
+      const fd = new FormData();
+      fd.append("file", file);
+      const res = await fetch(`${API}/upload`, { method: "POST", body: fd });
+      if (!res.ok) {
+        const err = await res.json().catch(() => ({}));
+        alert(err.detail || `Upload failed (${res.status})`);
+        return;
+      }
+      const data = await res.json();
+      insertAtCursor(`![${data.filename}](${data.url})`);
+    } finally {
+      setUploading(false);
+    }
+  };
+
+  const updateAutocomplete = (text, caret) => {
+    const before = text.slice(0, caret);
+    const lastOpen = before.lastIndexOf("[[");
+    const lastClose = before.lastIndexOf("]]");
+    if (lastOpen === -1 || lastOpen <= lastClose) {
+      setAc({ active: false, matches: [], selected: 0 });
+      return;
+    }
+    const partial = before.slice(lastOpen + 2);
+    if (partial.includes("\n") || partial.includes("]")) {
+      setAc({ active: false, matches: [], selected: 0 });
+      return;
+    }
+    const q = partial.toLowerCase();
+    const matches = notes
+      .filter((n) => n.title.toLowerCase().includes(q))
+      .slice(0, 8);
+    setAc({ active: matches.length > 0, matches, selected: 0 });
+  };
+
+  const handleChange = (e) => {
+    onChange(e.target.value);
+    updateAutocomplete(e.target.value, e.target.selectionStart);
+  };
+
+  const insertChoice = (title) => {
+    const ta = taRef.current;
+    if (!ta) return;
+    const caret = ta.selectionStart;
+    const before = value.slice(0, caret);
+    const lastOpen = before.lastIndexOf("[[");
+    if (lastOpen === -1) return;
+    const newValue =
+      value.slice(0, lastOpen + 2) + title + "]]" + value.slice(caret);
+    onChange(newValue);
+    setAc({ active: false, matches: [], selected: 0 });
+    setTimeout(() => {
+      ta.focus();
+      const newPos = lastOpen + 2 + title.length + 2;
+      ta.setSelectionRange(newPos, newPos);
+    }, 0);
+  };
+
+  const handleKeyDown = (e) => {
+    if (!ac.active) return;
+    if (e.key === "ArrowDown") {
+      e.preventDefault();
+      setAc((s) => ({
+        ...s,
+        selected: (s.selected + 1) % s.matches.length,
+      }));
+    } else if (e.key === "ArrowUp") {
+      e.preventDefault();
+      setAc((s) => ({
+        ...s,
+        selected: (s.selected - 1 + s.matches.length) % s.matches.length,
+      }));
+    } else if (e.key === "Enter" || e.key === "Tab") {
+      e.preventDefault();
+      insertChoice(ac.matches[ac.selected].title);
+    } else if (e.key === "Escape") {
+      e.preventDefault();
+      setAc({ active: false, matches: [], selected: 0 });
+    }
+  };
+
+  return (
+    <div className="editor-wrap">
+      <div className="editor-toolbar">
+        <button
+          type="button"
+          className="btn btn-mini"
+          onClick={() => fileRef.current?.click()}
+          disabled={uploading}
+        >
+          {uploading ? "Uploading..." : "+ Attach image / PDF"}
+        </button>
+        <input
+          ref={fileRef}
+          type="file"
+          accept="image/png,image/jpeg,image/gif,image/webp,application/pdf"
+          onChange={handleUpload}
+          style={{ display: "none" }}
+        />
+      </div>
+      <textarea
+        ref={taRef}
+        className="note-content-input"
+        placeholder={placeholder}
+        value={value}
+        onChange={handleChange}
+        onKeyDown={handleKeyDown}
+        onBlur={() =>
+          setTimeout(
+            () => setAc({ active: false, matches: [], selected: 0 }),
+            150
+          )
+        }
+      />
+      {ac.active && (
+        <ul className="autocomplete">
+          {ac.matches.map((n, i) => (
+            <li
+              key={n.id}
+              className={i === ac.selected ? "active" : ""}
+              onMouseDown={(e) => {
+                e.preventDefault();
+                insertChoice(n.title);
+              }}
+            >
+              {n.title}
+            </li>
+          ))}
+        </ul>
+      )}
+    </div>
+  );
+}
